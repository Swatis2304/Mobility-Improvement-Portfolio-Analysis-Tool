output$baseline_map <- renderLeaflet({
fd <- filtered_data()
area_map <- sf::st_transform(fd$area, 4326) %>%
sf::st_make_valid()
bbox <- sf::st_bbox(area_map)
leaflet() %>%
addTiles() %>%
addPolygons(
data = area_map,
fillColor = "yellow",
fillOpacity = 0.2,
color = "red",
weight = 3
) %>%
fitBounds(
lng1 = bbox["xmin"],
lat1 = bbox["ymin"],
lng2 = bbox["xmax"],
lat2 = bbox["ymax"]
)
})
